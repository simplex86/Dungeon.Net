<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Dungeon.TApplication"
        x:Class="Dungeon.TApplication.MainWindow"
        Title="Dungeon Generator v0.3.9"
        Width="1478" Height="978"
        MinWidth="1276" MinHeight="710"
        WindowStartupLocation="CenterScreen">
    <TabControl>
        <TabItem Header="Generation">
            <local:RectangularDungeonControl />
        </TabItem>
        <TabItem Header="Reconstruction">
            <local:ReconstructionControl />
        </TabItem>
    </TabControl>
</Window>
